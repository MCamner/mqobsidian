{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "context-card.v1",
  "type": "object",
  "required": [
    "schema",
    "repo",
    "role",
    "owns",
    "does_not_own",
    "reads_from",
    "writes_to",
    "use_when",
    "avoid_reading_unless_needed"
  ],
  "properties": {
    "schema": {
      "const": "context-card.v1"
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "owns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "does_not_own": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reads_from": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "writes_to": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "use_when": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "avoid_reading_unless_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "freshness": {
      "type": "string",
      "enum": ["current", "stale", "archived"]
    },
    "scope": {
      "type": "string",
      "enum": ["repo", "system", "cross-repo", "local-only"]
    },
    "publishability": {
      "type": "string",
      "enum": ["public-safe", "sanitized-example", "local-rich", "generated-target-artifact"]
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "repo-memory-index.v1",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "repos"
  ],
  "properties": {
    "schema": {
      "const": "repo-memory-index.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "card",
          "sources"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "card": {
            "type": "string",
            "minLength": 1
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "current_blockers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "integration_notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
